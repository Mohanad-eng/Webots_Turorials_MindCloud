<?xml version="1.0" encoding="utf-8"?>
<robot name="new_rover">

  <link name="base_link">
    <inertial>
      <origin xyz="0.00651 0 0.10801" rpy="0 0 0"/>
      <mass value="17.965"/>
      <inertia ixx="0.0928" ixy="0" ixz="0.00218" iyy="0.0718" iyz="0" izz="0.1320"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/base_link.STL"/>
      </geometry>
      <material name="gray"><color rgba="0.753 0.753 0.753 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- STEERING 1 (front left) -->
  <link name="steering1_Link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/steering1_Link.STL"/>
      </geometry>
    </visual>
  </link>
  <joint name="steering1_joint" type="revolute">
    <origin xyz="0.34672 0.2949 0.041107" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="steering1_Link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- WHEEL 1 (front left) -->
  <link name="wheel1_Link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel1_Link.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel1_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel1_joint" type="continuous">
    <origin xyz="0.045 -0.0782 -0.153784" rpy="0 0 0"/>
    <parent link="steering1_Link"/>
    <child link="wheel1_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- STEERING 2 (front right) -->
  <link name="steering2_Link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/steering2_Link.STL"/>
      </geometry>
    </visual>
  </link>
  <joint name="steering2_joint" type="revolute">
    <origin xyz="-0.34672 0.2949 0.041107" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="steering2_Link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- WHEEL 2 (front right) -->
  <link name="wheel2_Link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel2_Link.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel2_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel2_joint" type="continuous">
    <origin xyz="-0.045 -0.0782 -0.153783" rpy="0 0 0"/>
    <parent link="steering2_Link"/>
    <child link="wheel2_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- STEERING 3 (rear left) -->
  <link name="steering3_Link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/steering3_Link.STL"/>
      </geometry>
    </visual>
  </link>
  <joint name="steering3_joint" type="revolute">
    <origin xyz="0.34672 -0.2949 0.041107" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="steering3_Link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- WHEEL 3 (rear left) -->
  <link name="wheel3_Link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel3_Link.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel3_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel3_joint" type="continuous">
    <origin xyz="0.045 0.0782 -0.153782" rpy="0 0 0"/>
    <parent link="steering3_Link"/>
    <child link="wheel3_Link"/>
    <axis xyz="0 -1 0"/>
  </joint>

  <!-- STEERING 4 (rear right) -->
  <link name="steering4_Link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/steering4_Link.STL"/>
      </geometry>
    </visual>
  </link>
  <joint name="steering4_joint" type="revolute">
    <origin xyz="-0.34672 -0.2949 0.041107" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="steering4_Link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- WHEEL 4 (rear right) -->
  <link name="wheel4_Link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel4_Link.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://webots_pkg_sim/meshes/wheel4_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel4_joint" type="continuous">
    <origin xyz="-0.045 0.0782 -0.153782" rpy="0 0 0"/>
    <parent link="steering4_Link"/>
    <child link="wheel4_Link"/>
    <axis xyz="0 -1 0"/>
  </joint>

  <!-- OAK-D Camera -->
  <link name="oakd_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.02 0.1 0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="oakd_joint" type="fixed">
    <origin xyz="0.4 0 0.15" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="oakd_link"/>
  </joint>

  <link name="oakd_optical_link"/>
  <joint name="oakd_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="oakd_link"/>
    <child link="oakd_optical_link"/>
  </joint>

  <!-- Webots plugin -->
  <webots>
    <plugin type="webots_pkg_sim.webots_localization.RoverDriver"/>
  </webots>

</robot>