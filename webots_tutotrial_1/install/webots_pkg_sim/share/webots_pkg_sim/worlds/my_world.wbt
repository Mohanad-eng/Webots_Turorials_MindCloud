      device [ RotationalMotor { name "steering4_joint" maxVelocity 1.0 minPosition -1.57 maxPosition 1.57 } ]
      endPoint Solid {
        name "steering4_solid"
        translation -0.34672 -0.2949 0.041107
        children [
          Shape {
            castShadows FALSE
            appearance PBRAppearance { baseColor 0.3 0.3 0.3 roughness 0.7 }
